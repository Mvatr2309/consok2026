generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  slots       Slot[]
  experts     Expert[] @relation("ExpertToProduct")
}

model Expert {
  id           Int       @id @default(autoincrement())
  name         String
  photo        String
  description  String
  meetingLink  String    @default("")
  accessToken  String    @unique @default(uuid())
  login        String?   @unique
  passwordHash String?
  slots        Slot[]
  products     Product[] @relation("ExpertToProduct")
}

model Slot {
  id              Int       @id @default(autoincrement())
  dateTime        DateTime
  maxParticipants Int
  productId       Int
  expertId        Int
  bookings        Booking[]
  expert          Expert    @relation(fields: [expertId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
}

model Booking {
  id             Int       @id @default(autoincrement())
  name           String
  email          String
  slotId         Int
  createdAt      DateTime  @default(now())
  reminderSentAt DateTime?
  attended       Boolean   @default(false)
  slot           Slot          @relation(fields: [slotId], references: [id])
  consent        Consent?
  telegramSub    TelegramSub?
}

model Consent {
  id                  Int      @id @default(autoincrement())
  bookingId           Int      @unique
  personalData        Boolean
  meetingRecording    Boolean
  cookiePolicy        Boolean
  ip                  String   @default("")
  userAgent           String   @default("")
  createdAt           DateTime @default(now())
  booking             Booking  @relation(fields: [bookingId], references: [id])
}

model TelegramSub {
  id        Int      @id @default(autoincrement())
  chatId    String
  bookingId Int      @unique
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])
}

model Settings {
  id    Int    @id @default(1)
  key   String @unique
  value String
}
